<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.iso.plogues.request.model.dao.RequestMapper">
  
  <select id="countByUserIdJoinNo" resultType="_int">
	SELECT
	       COUNT(*)
	  FROM
	       JOIN_REQUEST
	 WHERE
	       JOIN_NO = #{joinNo}
	   AND
	       USER_ID = #{userId}
  </select>
  
  <insert id="requestJoin">
  	INSERT
  	  INTO
  	       JOIN_REQUEST
  	VALUES
  	       (
		   SEQ_PLG_JR.NEXTVAL
		 , #{aspiration}
		 , 'WAITING'
		 , #{joinNo}
		 , #{userId}
		   )
  </insert>
  
</mapper>